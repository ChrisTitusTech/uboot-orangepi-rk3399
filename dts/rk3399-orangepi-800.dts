// SPDX-License-Identifier: (GPL-2.0+ OR MIT)
/*
 * Copyright (c) 2022 Xunlong Software Co. Ltd.
 *
 * Device tree source for the Orange Pi 800 keyboard-PC (RK3399).
 * Ported from vendor DTS to mainline Linux format.
 *
 * Hardware:
 *   SoC:    Rockchip RK3399 (4x Cortex-A53 + 2x Cortex-A72)
 *   RAM:    4 GB LPDDR4
 *   eMMC:   64 GB (non-removable, /dev/mmcblk0)
 *   WiFi:   BCM43456 (AP6256) via SDIO
 *   BT:     BCM43456 via UART0
 *   PHY:    Motorcomm YT8531C 1GbE
 *   Audio:  ES8316 codec
 *   PMIC:   RK808-D + SYR827 (vdd_cpu_b) + SYR828 (vdd_gpu)
 *   VGA:    CH7517 eDP-to-VGA bridge on EDP port
 *   HDMI:   dw-hdmi @ ff940000
 *   Serial: UART2 (ff1a0000) @ 1500000 baud
 */
/dts-v1/;

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/leds/common.h>
#include <dt-bindings/pinctrl/rockchip.h>
#include "rk3399.dtsi"
#include "rk3399-opp.dtsi"

/ {
model = "Xunlong Orange Pi 800";
compatible = "xunlong,orangepi-800", "rockchip,rk3399";

aliases {
ethernet0 = &gmac;
mmc0 = &sdio0;
mmc1 = &sdmmc;
mmc2 = &sdhci;
};

chosen {
stdout-path = "serial2:1500000n8";
};

/*
 * 4 GB LPDDR4: 3840 MB low + 256 MB above 4 GB boundary.
 * U-Boot will update this node from DRAM init data.
 */
memory@00000000 {
device_type = "memory";
reg = <0x0 0x00000000 0x0 0xf0000000>,
      <0x0 0x100000000 0x0 0x10000000>;
};

/* ---------- Fixed regulators ---------- */

/* Root power supply — 5 V USB-C PD input */
vcc_sys: vcc-sys-regulator {
compatible = "regulator-fixed";
regulator-name = "vcc_sys";
regulator-always-on;
regulator-boot-on;
};

vcc5v0_sys: vcc5v0-sys-regulator {
compatible = "regulator-fixed";
regulator-name = "vcc5v0_sys";
regulator-always-on;
regulator-boot-on;
regulator-min-microvolt = <5000000>;
regulator-max-microvolt = <5000000>;
vin-supply = <&vcc_sys>;
};

vcc3v3_sys: vcc3v3-sys-regulator {
compatible = "regulator-fixed";
regulator-name = "vcc3v3_sys";
regulator-always-on;
regulator-boot-on;
regulator-min-microvolt = <3300000>;
regulator-max-microvolt = <3300000>;
vin-supply = <&vcc_sys>;

regulator-state-mem {
regulator-on-in-suspend;
};
};

/* SD card VMC — switched by GPIO0_PA1 */
vcc3v0_sd: vcc3v0-sd-regulator {
compatible = "regulator-fixed";
enable-active-high;
gpio = <&gpio0 RK_PA1 GPIO_ACTIVE_HIGH>;
pinctrl-names = "default";
pinctrl-0 = <&sdmmc0_pwr_h>;
regulator-name = "vcc3v0_sd";
regulator-always-on;
regulator-min-microvolt = <3000000>;
regulator-max-microvolt = <3000000>;
vin-supply = <&vcc3v3_sys>;

regulator-state-mem {
regulator-off-in-suspend;
};
};

/* USB host 5 V power (VBUS for USB2 host PHY ports) */
usb_vbus: usb-vbus-regulator {
compatible = "regulator-fixed";
regulator-name = "usb_vbus";
regulator-always-on;
regulator-boot-on;
regulator-min-microvolt = <5000000>;
regulator-max-microvolt = <5000000>;
vin-supply = <&vcc5v0_sys>;

regulator-state-mem {
regulator-on-in-suspend;
};
};

/* USB3 host VBUS (USB3/Type-C host ports) */
usb3_vbus: usb3-vbus-regulator {
compatible = "regulator-fixed";
regulator-name = "usb3_vbus";
regulator-always-on;
regulator-boot-on;
regulator-min-microvolt = <5000000>;
regulator-max-microvolt = <5000000>;
vin-supply = <&vcc5v0_sys>;

regulator-state-mem {
regulator-on-in-suspend;
};
};

/*
 * VDD_LOG — center-logic domain supply.
 * U2106 SY8088AAC buck converter, FB controlled by PWM3 (inverted).
 * Default hardware voltage ~0.945 V per schematic.
 */
vdd_log: vdd-log-regulator {
compatible = "pwm-regulator";
pwms = <&pwm3 0 25000 1>;
pwm-supply = <&vcc3v3_sys>;
regulator-name = "vdd_log";
regulator-min-microvolt = <750000>;
regulator-max-microvolt = <1400000>;
regulator-always-on;
regulator-boot-on;
};

/* ---------- External clocks ---------- */

/*
 * 125 MHz RGMII reference clock supplied by the YT8531C PHY
 * CLKOUT pin back to the RK3399 GMAC controller.
 */
clkin_gmac: external-gmac-clock {
compatible = "fixed-clock";
clock-frequency = <125000000>;
clock-output-names = "clkin_gmac";
#clock-cells = <0>;
};

/* ---------- WiFi power sequencing ---------- */

sdio_pwrseq: sdio-pwrseq {
compatible = "mmc-pwrseq-simple";
/*
 * RK808 CLKOUT2 (32 kHz) is the reference clock for the
 * AP6256 WiFi module.
 */
clocks = <&rk808 1>;
clock-names = "ext_clock";
pinctrl-names = "default";
pinctrl-0 = <&wifi_reg_on_h>;
/* WL_REG_ON: active-high enable, maps to ACTIVE_LOW on reset */
reset-gpios = <&gpio0 RK_PB2 GPIO_ACTIVE_LOW>;
};

/* ---------- Audio ---------- */

es8316_sound: es8316-sound {
compatible = "simple-audio-card";
simple-audio-card,name = "rockchip,es8316-codec";
simple-audio-card,format = "i2s";
simple-audio-card,mclk-fs = <256>;
simple-audio-card,widgets =
"Microphone", "Mic Jack",
"Headphone", "Headphones";
simple-audio-card,routing =
"MIC1", "Mic Jack",
"Headphones", "HPOL",
"Headphones", "HPOR";

simple-audio-card,cpu {
sound-dai = <&i2s0>;
};

simple-audio-card,codec {
sound-dai = <&es8316>;
};
};

hdmi_sound: hdmi-sound {
compatible = "simple-audio-card";
simple-audio-card,name = "hdmi";
simple-audio-card,format = "i2s";
simple-audio-card,mclk-fs = <256>;

simple-audio-card,cpu {
sound-dai = <&i2s2>;
};

simple-audio-card,codec {
sound-dai = <&hdmi>;
bitclock-master;
frame-master;
};
};

/* ---------- Input ---------- */

/* Volume Up / Down via SARADC channel 1 */
adc_keys: adc-keys {
compatible = "adc-keys";
io-channels = <&saradc 1>;
io-channel-names = "buttons";
poll-interval = <100>;
keyup-threshold-microvolt = <1800000>;

button-up {
label = "Volume Up";
linux,code = <KEY_VOLUMEUP>;
press-threshold-microvolt = <100000>;
};

button-down {
label = "Volume Down";
linux,code = <KEY_VOLUMEDOWN>;
press-threshold-microvolt = <300000>;
};
};

/* Power button — GPIO0_PA5, active-low */
gpio_keys: gpio-keys {
compatible = "gpio-keys";
#address-cells = <1>;
#size-cells = <0>;
autorepeat;
pinctrl-names = "default";
pinctrl-0 = <&power_key>;

button@0 {
gpios = <&gpio0 RK_PA5 GPIO_ACTIVE_LOW>;
linux,code = <KEY_POWER>;
label = "GPIO Key Power";
linux,input-type = <1>;
gpio-key,wakeup = <1>;
debounce-interval = <100>;
};
};

/* ---------- LEDs ---------- */

gpio_leds: gpio-leds {
compatible = "gpio-leds";
pinctrl-names = "default";
pinctrl-0 = <&leds_gpio>;

led-power {
gpios = <&gpio1 RK_PA1 GPIO_ACTIVE_HIGH>;
label = "power_led";
linux,default-trigger = "none";
default-state = "on";
};

led-num {
gpios = <&gpio4 RK_PD5 GPIO_ACTIVE_HIGH>;
label = "num_led";
function = LED_FUNCTION_KBD_NUMLOCK;
linux,default-trigger = "kbd-numlock";
default-state = "off";
};

led-caps {
gpios = <&gpio3 RK_PD4 GPIO_ACTIVE_HIGH>;
label = "caps_led";
function = LED_FUNCTION_KBD_CAPSLOCK;
linux,default-trigger = "kbd-capslock";
default-state = "off";
};
};
};

/* ---------- CPU voltage supplies ---------- */

&cpu_l0 { cpu-supply = <&vdd_cpu_l>; };
&cpu_l1 { cpu-supply = <&vdd_cpu_l>; };
&cpu_l2 { cpu-supply = <&vdd_cpu_l>; };
&cpu_l3 { cpu-supply = <&vdd_cpu_l>; };
&cpu_b0 { cpu-supply = <&vdd_cpu_b>; };
&cpu_b1 { cpu-supply = <&vdd_cpu_b>; };

/* ---------- eMMC PHY ---------- */

&emmc_phy {
status = "okay";
};

/* ---------- Ethernet (GMAC) ---------- */

&gmac {
assigned-clocks = <&cru SCLK_RMII_SRC>;
assigned-clock-parents = <&clkin_gmac>;
clock_in_out = "input";
phy-supply = <&vcc3v3_s3>;
phy-mode = "rgmii";
pinctrl-names = "default";
pinctrl-0 = <&rgmii_pins>;
tx_delay = <0x28>;
rx_delay = <0x11>;
status = "okay";

mdio {
compatible = "snps,dwmac-mdio";
#address-cells = <1>;
#size-cells = <0>;

phy@1 {
compatible = "motorcomm,yt8531";
reg = <1>;
interrupt-parent = <&gpio3>;
interrupts = <RK_PB2 IRQ_TYPE_LEVEL_LOW>;
motorcomm,clk-out-frequency-hz = <125000000>;
reset-gpios = <&gpio3 RK_PB7 GPIO_ACTIVE_LOW>;
reset-assert-us = <10000>;
reset-deassert-us = <30000>;
};
};
};

/* ---------- GPU ---------- */

&gpu {
mali-supply = <&vdd_gpu>;
status = "okay";
};

/* ---------- HDMI ---------- */

&hdmi {
ddc-i2c-bus = <&i2c7>;
pinctrl-names = "default";
pinctrl-0 = <&hdmi_cec>;
status = "okay";
};

&hdmi_in_vopb {
status = "okay";
};

&hdmi_in_vopl {
status = "disabled";
};

/* ---------- I2S / Audio clocking ---------- */

&i2s0 {
#sound-dai-cells = <0>;
pinctrl-names = "default";
pinctrl-0 = <&i2s0_8ch_bus>;
rockchip,playback-channels = <8>;
rockchip,capture-channels = <8>;
status = "okay";
};

&i2s2 {
#sound-dai-cells = <0>;
status = "okay";
};

/* ---------- I2C buses ---------- */

/* PMU I2C: RK808 PMIC, SYR827 (vdd_cpu_b), SYR828 (vdd_gpu) */
&i2c0 {
clock-frequency = <400000>;
i2c-scl-rising-time-ns = <168>;
i2c-scl-falling-time-ns = <4>;
status = "okay";

rk808: pmic@1b {
compatible = "rockchip,rk808";
reg = <0x1b>;
interrupt-parent = <&gpio1>;
interrupts = <RK_PC5 IRQ_TYPE_LEVEL_LOW>;
#clock-cells = <1>;
clock-output-names = "rk808-clko1", "rk808-clko2";
pinctrl-names = "default";
pinctrl-0 = <&pmic_int_l>;
rockchip,system-power-controller;
wakeup-source;

vcc1-supply = <&vcc3v3_sys>;
vcc2-supply = <&vcc3v3_sys>;
vcc3-supply = <&vcc3v3_sys>;
vcc4-supply = <&vcc3v3_sys>;
vcc6-supply = <&vcc3v3_sys>;
vcc7-supply = <&vcc3v3_sys>;
vcc8-supply = <&vcc3v3_sys>;
vcc9-supply = <&vcc3v3_sys>;
vcc10-supply = <&vcc3v3_sys>;
vcc11-supply = <&vcc3v3_sys>;
vcc12-supply = <&vcc3v3_sys>;
vddio-supply = <&vcc_3v0>;

regulators {
vdd_center: DCDC_REG1 {
regulator-name = "vdd_center";
regulator-always-on;
regulator-boot-on;
regulator-min-microvolt = <700000>;
regulator-max-microvolt = <1500000>;
regulator-ramp-delay = <6001>;

regulator-state-mem {
regulator-off-in-suspend;
};
};

vdd_cpu_l: DCDC_REG2 {
regulator-name = "vdd_cpu_l";
regulator-always-on;
regulator-boot-on;
regulator-min-microvolt = <700000>;
regulator-max-microvolt = <1500000>;
regulator-ramp-delay = <6001>;

regulator-state-mem {
regulator-off-in-suspend;
};
};

vcc_ddr: DCDC_REG3 {
regulator-name = "vcc_ddr";
regulator-always-on;
regulator-boot-on;

regulator-state-mem {
regulator-on-in-suspend;
};
};

vcc_1v8: DCDC_REG4 {
regulator-name = "vcc_1v8";
regulator-always-on;
regulator-boot-on;
regulator-min-microvolt = <1800000>;
regulator-max-microvolt = <3300000>;

regulator-state-mem {
regulator-on-in-suspend;
regulator-suspend-microvolt = <1800000>;
};
};

vcc1v8_dvp: LDO_REG1 {
regulator-name = "vcc1v8_dvp";
regulator-always-on;
regulator-boot-on;
regulator-min-microvolt = <1800000>;
regulator-max-microvolt = <3400000>;

regulator-state-mem {
regulator-off-in-suspend;
};
};

vcc3v0_tp: LDO_REG2 {
regulator-name = "vcc3v0_tp";
regulator-always-on;
regulator-boot-on;
regulator-min-microvolt = <1800000>;
regulator-max-microvolt = <3400000>;

regulator-state-mem {
regulator-off-in-suspend;
};
};

vcc1v8_pmu: LDO_REG3 {
regulator-name = "vcc1v8_pmu";
regulator-always-on;
regulator-boot-on;
regulator-min-microvolt = <1800000>;
regulator-max-microvolt = <1800000>;

regulator-state-mem {
regulator-on-in-suspend;
regulator-suspend-microvolt = <1800000>;
};
};

vcc_sdio: LDO_REG4 {
regulator-name = "vcc_sdio";
regulator-always-on;
regulator-boot-on;
regulator-min-microvolt = <1800000>;
regulator-max-microvolt = <3400000>;

regulator-state-mem {
regulator-on-in-suspend;
regulator-suspend-microvolt = <3000000>;
};
};

vcca3v0_codec: LDO_REG5 {
regulator-name = "vcca3v0_codec";
regulator-always-on;
regulator-boot-on;
regulator-min-microvolt = <1800000>;
regulator-max-microvolt = <3400000>;

regulator-state-mem {
regulator-off-in-suspend;
};
};

vcc_1v5: LDO_REG6 {
regulator-name = "vcc_1v5";
regulator-always-on;
regulator-boot-on;

regulator-state-mem {
regulator-on-in-suspend;
regulator-suspend-microvolt = <1500000>;
};
};

vcca1v8_codec: LDO_REG7 {
regulator-name = "vcca1v8_codec";
regulator-always-on;
regulator-boot-on;
regulator-min-microvolt = <1800000>;
regulator-max-microvolt = <1800000>;

regulator-state-mem {
regulator-off-in-suspend;
};
};

vcc_3v0: LDO_REG8 {
regulator-name = "vcc_3v0";
regulator-always-on;
regulator-boot-on;
regulator-min-microvolt = <3000000>;
regulator-max-microvolt = <3000000>;

regulator-state-mem {
regulator-on-in-suspend;
regulator-suspend-microvolt = <3000000>;
};
};

vcc3v3_s3: SWITCH_REG1 {
regulator-name = "vcc3v3_s3";
regulator-always-on;
regulator-boot-on;

regulator-state-mem {
regulator-on-in-suspend;
};
};

vcc3v3_s0: SWITCH_REG2 {
regulator-name = "vcc3v3_s0";
regulator-always-on;
regulator-boot-on;

regulator-state-mem {
regulator-off-in-suspend;
};
};
};
};

/* SYR837PKC (schematic U2105): vdd_cpu_b — big cluster CPU supply.
 * Primary compatible is syr837 (6.25 mV step); fall back to syr827
 * (12.5 mV step) for older kernel trees.
 */
vdd_cpu_b: regulator@40 {
compatible = "silergy,syr837", "silergy,syr827";
reg = <0x40>;
fcs,suspend-voltage-selector = <1>;
pinctrl-names = "default";
pinctrl-0 = <&cpu_b_sleep>;
regulator-name = "vdd_cpu_b";
regulator-always-on;
regulator-boot-on;
regulator-min-microvolt = <712500>;
regulator-max-microvolt = <1500000>;
regulator-ramp-delay = <1000>;
vin-supply = <&vcc3v3_sys>;

regulator-state-mem {
regulator-off-in-suspend;
};
};

/* SYR838PKC (schematic U2104): vdd_gpu — GPU supply.
 * Primary compatible is syr838 (6.25 mV step); fall back to syr828.
 */
vdd_gpu: regulator@41 {
compatible = "silergy,syr838", "silergy,syr828";
reg = <0x41>;
fcs,suspend-voltage-selector = <1>;
pinctrl-names = "default";
pinctrl-0 = <&gpu_sleep>;
regulator-name = "vdd_gpu";
regulator-always-on;
regulator-boot-on;
regulator-min-microvolt = <712500>;
regulator-max-microvolt = <1500000>;
regulator-ramp-delay = <1000>;
vin-supply = <&vcc3v3_sys>;

regulator-state-mem {
regulator-off-in-suspend;
};
};
};

/* Codec + RTC */
&i2c1 {
i2c-scl-rising-time-ns = <450>;
i2c-scl-falling-time-ns = <15>;
status = "okay";

es8316: codec@11 {
compatible = "everest,es8316";
reg = <0x11>;
clocks = <&cru SCLK_I2S0>;
clock-names = "mclk";
#sound-dai-cells = <0>;
hp-gpios = <&gpio4 RK_PD4 GPIO_ACTIVE_HIGH>;
spk-gpios = <&gpio0 RK_PB3 GPIO_ACTIVE_HIGH>;
};

rtc@32 {
compatible = "ricoh,rs5c372a";
reg = <0x32>;
};
};

/* HDMI DDC — driven by dw-hdmi hardware I2C */
&i2c7 {
status = "okay";
};

/* ---------- IO domains ---------- */

&io_domains {
bt656-supply = <&vcc1v8_dvp>;
audio-supply = <&vcca1v8_codec>;
sdmmc-supply = <&vcc_sdio>;
gpio1830-supply = <&vcc_3v0>;
status = "okay";
};

&pmu_io_domains {
pmu1830-supply = <&vcc1v8_pmu>;
status = "okay";
};

/* ---------- MMC / Storage ---------- */

/* WiFi SDIO (AP6256 / BCM43456) */
&sdio0 {
bus-width = <4>;
cap-sdio-irq;
disable-wp;
keep-power-in-suspend;
mmc-pwrseq = <&sdio_pwrseq>;
non-removable;
pinctrl-names = "default";
pinctrl-0 = <&sdio0_bus4 &sdio0_cmd &sdio0_clk>;
sd-uhs-sdr104;
max-frequency = <150000000>;
status = "okay";

brcmf: wifi@1 {
compatible = "brcm,bcm4329-fmac";
reg = <1>;
interrupt-parent = <&gpio0>;
interrupts = <RK_PA3 IRQ_TYPE_LEVEL_HIGH>;
interrupt-names = "host-wake";
};
};

/* microSD card */
&sdmmc {
bus-width = <4>;
cap-mmc-highspeed;
cap-sd-highspeed;
disable-wp;
cd-gpios = <&gpio0 RK_PA7 GPIO_ACTIVE_LOW>;
pinctrl-names = "default";
pinctrl-0 = <&sdmmc_bus4 &sdmmc_clk &sdmmc_cmd>;
vmmc-supply = <&vcc3v0_sd>;
vqmmc-supply = <&vcc_sdio>;
status = "okay";
};

/* eMMC 64 GB HS400 (always present, /dev/mmcblk0) */
&sdhci {
bus-width = <8>;
mmc-hs400-1_8v;
non-removable;
status = "okay";
};

/* ---------- Temperature / ADC ---------- */

&saradc {
vref-supply = <&vcc_1v8>;
status = "okay";
};

&tsadc {
/* hw_tshut mode 1 = CRU, polarity 1 = active high */
rockchip,hw-tshut-mode = <1>;
rockchip,hw-tshut-polarity = <1>;
status = "okay";
};

/* ---------- Serial ---------- */

/* Console */
&uart2 {
status = "okay";
};

/*
 * Bluetooth UART — AP6256 BT (BCM43456).
 * Uses UART0 with full hardware flow control.
 */
&uart0 {
pinctrl-names = "default";
pinctrl-0 = <&uart0_xfer &uart0_cts &uart0_rts>;
uart-has-rtscts;
status = "okay";

bluetooth {
compatible = "brcm,bcm43438-bt";
clocks = <&rk808 1>;
clock-names = "lpo";
device-wakeup-gpios = <&gpio2 RK_PD2 GPIO_ACTIVE_HIGH>;
host-wakeup-gpios = <&gpio0 RK_PA4 GPIO_ACTIVE_HIGH>;
shutdown-gpios = <&gpio0 RK_PB1 GPIO_ACTIVE_HIGH>;
vbat-supply = <&vcc3v3_sys>;
vddio-supply = <&vcc_1v8>;
};
};

/* ---------- USB ---------- */

&u2phy0 {
status = "okay";
};

&u2phy0_host {
phy-supply = <&usb_vbus>;
status = "okay";
};

&u2phy0_otg {
status = "okay";
};

&u2phy1 {
status = "okay";
};

&u2phy1_host {
phy-supply = <&usb3_vbus>;
status = "okay";
};

&u2phy1_otg {
status = "okay";
};

&usb_host0_ehci {
status = "okay";
};

&usb_host0_ohci {
status = "okay";
};

&usb_host1_ehci {
status = "okay";
};

&usb_host1_ohci {
status = "okay";
};

&usbdrd3_0 {
dr_mode = "host";
status = "okay";
};

&usbdrd3_1 {
dr_mode = "host";
status = "okay";
};

&tcphy0 {
status = "okay";
};

&tcphy1 {
status = "okay";
};

/* ---------- Display ---------- */

/* VOP-big → HDMI */
&vopb {
status = "okay";
assigned-clocks = <&cru DCLK_VOP0_DIV>;
assigned-clock-parents = <&cru PLL_VPLL>;
};

&vopb_mmu {
status = "okay";
};

/* VOP-little → eDP (for CH7517 eDP-to-VGA bridge) */
&vopl {
status = "okay";
assigned-clocks = <&cru DCLK_VOP1_DIV>;
assigned-clock-parents = <&cru PLL_CPLL>;
};

&vopl_mmu {
status = "okay";
};

/*
 * eDP → CH7517 eDP-to-VGA bridge.
 * The CH7517 does not yet have a mainline DRM bridge driver;
 * enable the eDP controller so it is usable when the driver lands.
 */
&edp {
force-hpd;
pinctrl-names = "default";
pinctrl-0 = <&edp_hpd>;
status = "okay";
};

&edp_in_vopb {
status = "disabled";
};

&edp_in_vopl {
status = "okay";
};

/* PWM3 — used for VDD_LOG regulation (SY8088AAC U2106) */
&pwm3 {
status = "okay";
};

/* ---------- VPU / Video decode ---------- */

/* Hantro G1/G2 (H.264, VP8, MPEG-2, JPEG, HEVC, VP9) */
&vpu {
status = "okay";
};

/* rkvdec engine (H.264 / HEVC alternate decoder) */
&vdec {
status = "okay";
};

/* ---------- Board-specific pinctrl groups ---------- */

&pinctrl {
/* PMIC int, CPU-B voltage sleep, GPU voltage sleep */
pmic {
pmic_int_l: pmic-int-l {
rockchip,pins =
<1 RK_PC5 RK_FUNC_GPIO &pcfg_pull_up>;
};

cpu_b_sleep: cpu-b-sleep {
rockchip,pins =
<1 RK_PC1 RK_FUNC_GPIO &pcfg_pull_down>;
};

gpu_sleep: gpu-sleep {
rockchip,pins =
<1 RK_PB6 RK_FUNC_GPIO &pcfg_pull_down>;
};
};

/* SD card power rail enable */
sd {
sdmmc0_pwr_h: sdmmc0-pwr-h {
rockchip,pins =
<0 RK_PA1 RK_FUNC_GPIO &pcfg_pull_none>;
};
};

/* WiFi chip enable (WL_REG_ON) */
sdio-pwrseq {
wifi_reg_on_h: wifi-reg-on-h {
rockchip,pins =
<0 RK_PB2 RK_FUNC_GPIO &pcfg_pull_none>;
};
};

/* USB host 5 V enable */
usb2 {
vcc5v0_host_en: vcc5v0-host-en {
rockchip,pins =
<4 RK_PD1 RK_FUNC_GPIO &pcfg_pull_none>;
};
};

/* Bluetooth chip enable and wake lines */
bluetooth {
bt_reg_on_h: bt-reg-on-h {
rockchip,pins =
<0 RK_PB1 RK_FUNC_GPIO &pcfg_pull_none>;
};

bt_host_wake_l: bt-host-wake-l {
rockchip,pins =
<0 RK_PA4 RK_FUNC_GPIO &pcfg_pull_none>;
};

bt_wake_l: bt-wake-l {
rockchip,pins =
<2 RK_PD2 RK_FUNC_GPIO &pcfg_pull_none>;
};
};

/* Keyboard status LEDs */
leds {
leds_gpio: leds-gpio {
rockchip,pins =
<1 RK_PA1 RK_FUNC_GPIO &pcfg_pull_none>,
<4 RK_PD5 RK_FUNC_GPIO &pcfg_pull_none>,
<3 RK_PD4 RK_FUNC_GPIO &pcfg_pull_none>;
};
};

/* Power button */
keys {
power_key: power-key {
rockchip,pins =
<0 RK_PA5 RK_FUNC_GPIO &pcfg_pull_up>;
};
};
};
